{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build FS Lab 4",
            "command": "gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "main.c",
                "fs.c",
                "kernel.c",
                "-o",
                "${fileDirname}\\fs_lab4.exe",
                "-std=c11",
                "-Wall"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}